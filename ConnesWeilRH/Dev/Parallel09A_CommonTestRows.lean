import ConnesWeilRH.Route.CC20RouteRealization

/-!
# 09A package source-data common-test row audit

This scratch module is owned by the 09A parallel lane.  It does not integrate
the route.  It records the constructor-level evidence for the common-test row:
whether the finite-prime source-data owner is forced to use the same test
function as the route-backed test.
-/

namespace ConnesWeilRH
namespace Dev
namespace Parallel09A

open Route Source

/- The ordinary expanded-package constructor sets the route test to
`pkg.commonTest.sourceTest` and carries `pkg.commonFinitePrimeArithmeticSourceDataOwner`
as the source-data owner.  Therefore the 09A row reduces exactly to the package
owner/common-test equality. -/
theorem expandedSourcePackage_commonTestRow_iff
    (pkg : Source.SourceObject.SourceObjectPackage)
    (front : Route.ExpandedSourceFixedSTestFrontEnd pkg) :
    (Route.SourceBackedFixedSTest.ofExpandedSourcePackage
        pkg front).finitePrimeSourceDataOwner.commonTestFunction =
        (Route.SourceBackedFixedSTest.ofExpandedSourcePackage pkg front).weilTest â†”
      pkg.commonFinitePrimeArithmeticSourceDataOwner.commonTestFunction =
        pkg.commonTest.sourceTest := by
  rfl

/- The lower `SourceObjectCommonData` layer does store the missing equality.
This shows the relevant provenance exists before packaging. -/
theorem sourceObjectCommonData_has_commonTestRow
    {base : Source.SourceObjectTheoremBasePackage}
    (common : Source.SourceObjectCommonData base) :
    common.commonFinitePrimeArithmeticSourceDataOwner.commonTestFunction =
      common.commonTest.sourceTest :=
  common.commonFinitePrimeArithmeticSourceData_commonTest

/- But the public `SourceObjectPackage` shape does not expose the corresponding
row as a field; after packaging, the route-facing equality is exactly the
standalone owner/common-test equation. -/
theorem sourceObjectPackage_commonTestRow_is_standalone
    (pkg : Source.SourceObject.SourceObjectPackage) :
    pkg.commonFinitePrimeArithmeticSourceDataOwner.commonTestFunction =
        pkg.commonTest.sourceTest â†”
      pkg.commonFinitePrimeArithmeticSourceDataOwner.commonTestFunction =
        pkg.commonTest.sourceTest := by
  rfl

/- The square detector helper sets `weilTest` to the routed square test and
copies the caller-supplied source-data owner unchanged.  Thus 09A is not
definitionally generated by this constructor; it is exactly an external
same-test requirement on `sourceDataOwner`. -/
theorem yoshidaDetectorSquare_commonTestRow_iff
    {rho : â„‚} {inputs : Route.RouteInputs}
    (base : Route.SourceBackedFixedSTest inputs)
    (sourceDataOwner :
      Source.CCM25Concrete.FinitePrimeSourceData.CommonFinitePrimeArithmeticSourceData
        inputs.ccm25.weilSymbols)
    (detector :
      YoshidaDetector
        normalizedCC20TestSpace cc20TripleFiniteVanishingSet rho)
    (rows :
      Route.NormalizedRouteBackedYoshidaDetectorSquareFixedSTestRows detector) :
    (Route.sourceBackedFixedSTestWithNormalizedYoshidaDetectorSquare
        base sourceDataOwner detector rows).finitePrimeSourceDataOwner.commonTestFunction =
        (Route.sourceBackedFixedSTestWithNormalizedYoshidaDetectorSquare
          base sourceDataOwner detector rows).weilTest â†”
      sourceDataOwner.commonTestFunction =
        normalizedCC20TestSpace.toRouteTest
          (normalizedCC20TestSpace.starConvolution detector.test) := by
  rfl

end Parallel09A
end Dev
end ConnesWeilRH
