import ConnesWeilRH.Source.CCM25Concrete.CCM24FiniteSGramProjectionCalculus

/-!
# Collapse of the Gram derivative to the orthogonal projection flow

The rectangular frame derivative is rewritten using the complete same-object
Euler generator.  The Gram-inverse correction then removes both diagonal
blocks, leaving exactly the two completed boundary crossings.
-/

namespace ConnesWeilRH
namespace Source
namespace CCM25Concrete
namespace CCM24FiniteSGramFlowCollapse

open CC20Concrete
open CCM24FiniteSProjectionTrace
open CCM24FiniteSParameterizedEulerGenerator
open CCM24FiniteSParameterizedEulerProduct
open CCM24FiniteSParameterizedEulerCommutation
open CCM24FiniteSParameterizedEulerEquiv
open CCM24FiniteSParameterizedSoninProjection
open CCM24FiniteSFrameGramCalculus
open CCM24FiniteSGramInverseCalculus
open CCM24FiniteSGramProjectionCalculus
open CCM24FiniteSOrthogonalProjectionFlow
open _root_.ConnesWeilRH.CC20Concrete

noncomputable local instance sourceSoninCompleteSpace
    (lambda : CCM24SoninScale) :
    CompleteSpace (sourceSoninCarrier lambda) :=
  (ccm24ArchimedeanSoninClosedSubspace lambda).isClosed.completeSpace_coe

/-- The rectangular frame derivative is generated by the complete additive
Euler generator on the ambient carrier. -/
theorem parameterizedSoninFrameDerivative_eq_generator_comp_frame
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    parameterizedSoninFrameDerivative lambda alpha S =
      parameterizedFiniteEulerGenerator alpha S ∘L
        parameterizedSoninFrame lambda alpha S := by
  apply ContinuousLinearMap.ext
  intro u
  change parameterizedFiniteEulerDerivative alpha S u =
    parameterizedFiniteEulerGenerator alpha S
      (parameterizedFiniteEulerFactor alpha S u)
  have h := congrArg
    (fun A : finiteSCarrier →L[ℂ] finiteSCarrier => A u)
    (parameterizedFiniteEulerGenerator_mul_factor alpha S halpha)
  simpa only [ContinuousLinearMap.mul_apply] using h.symm

theorem adjoint_parameterizedSoninFrameDerivative_eq
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    ContinuousLinearMap.adjoint
        (parameterizedSoninFrameDerivative lambda alpha S) =
      ContinuousLinearMap.adjoint
          (parameterizedSoninFrame lambda alpha S) ∘L
        ContinuousLinearMap.adjoint
          (parameterizedFiniteEulerGenerator alpha S) := by
  rw [parameterizedSoninFrameDerivative_eq_generator_comp_frame
    lambda alpha S halpha]
  exact ContinuousLinearMap.adjoint_comp _ _

/-- Left frame-variation term equals `X P`. -/
theorem frameDerivative_gramInv_adjoint_eq_generator_mul_projection
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    (parameterizedSoninFrameDerivative lambda alpha S ∘L
        parameterizedSoninGramInv lambda alpha S halpha) ∘L
      ContinuousLinearMap.adjoint
        (parameterizedSoninFrame lambda alpha S) =
      parameterizedFiniteEulerGenerator alpha S *
        parameterizedCanonicalGramProjection lambda alpha S := by
  rw [parameterizedSoninFrameDerivative_eq_generator_comp_frame
    lambda alpha S halpha]
  unfold parameterizedCanonicalGramProjection gramCorrectedProjection
  rw [ringInverse_parameterizedSoninGram lambda alpha S halpha]
  apply ContinuousLinearMap.ext
  intro u
  rfl

/-- Adjoint frame-variation term equals `P X^dagger`. -/
theorem frame_gramInv_adjointDerivative_eq_projection_mul_adjointGenerator
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    (parameterizedSoninFrame lambda alpha S ∘L
        parameterizedSoninGramInv lambda alpha S halpha) ∘L
      ContinuousLinearMap.adjoint
        (parameterizedSoninFrameDerivative lambda alpha S) =
      parameterizedCanonicalGramProjection lambda alpha S *
        ContinuousLinearMap.adjoint
          (parameterizedFiniteEulerGenerator alpha S) := by
  rw [adjoint_parameterizedSoninFrameDerivative_eq
    lambda alpha S halpha]
  unfold parameterizedCanonicalGramProjection gramCorrectedProjection
  rw [ringInverse_parameterizedSoninGram lambda alpha S halpha]
  apply ContinuousLinearMap.ext
  intro u
  rfl

/-- The Gram-inverse derivative is exactly the negative sum of the two
diagonal projection blocks. -/
theorem frame_gramInverseDerivative_adjoint_eq_negative_diagonalBlocks
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    (parameterizedSoninFrame lambda alpha S ∘L
        parameterizedSoninGramInverseDerivative lambda alpha S halpha) ∘L
      ContinuousLinearMap.adjoint
        (parameterizedSoninFrame lambda alpha S) =
      -(parameterizedCanonicalGramProjection lambda alpha S *
          parameterizedFiniteEulerGenerator alpha S *
          parameterizedCanonicalGramProjection lambda alpha S +
        parameterizedCanonicalGramProjection lambda alpha S *
          ContinuousLinearMap.adjoint
            (parameterizedFiniteEulerGenerator alpha S) *
          parameterizedCanonicalGramProjection lambda alpha S) := by
  unfold parameterizedSoninGramInverseDerivative
    parameterizedSoninGramDerivative
    parameterizedCanonicalGramProjection gramCorrectedProjection
  rw [ringInverse_parameterizedSoninGram lambda alpha S halpha]
  rw [adjoint_parameterizedSoninFrameDerivative_eq
      lambda alpha S halpha,
    parameterizedSoninFrameDerivative_eq_generator_comp_frame
      lambda alpha S halpha]
  apply ContinuousLinearMap.ext
  intro u
  simp only [ContinuousLinearMap.comp_apply,
    ContinuousLinearMap.neg_apply, ContinuousLinearMap.add_apply,
    map_neg, map_add, ContinuousLinearMap.mul_apply]
  abel

/-- The full Gram derivative is the expanded orthogonal flow. -/
theorem parameterizedCanonicalGramProjectionDerivative_eq_expandedFlow
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    parameterizedCanonicalGramProjectionDerivative lambda alpha S halpha =
      parameterizedFiniteEulerGenerator alpha S *
          parameterizedCanonicalGramProjection lambda alpha S +
        parameterizedCanonicalGramProjection lambda alpha S *
          ContinuousLinearMap.adjoint
            (parameterizedFiniteEulerGenerator alpha S) -
        parameterizedCanonicalGramProjection lambda alpha S *
          parameterizedFiniteEulerGenerator alpha S *
          parameterizedCanonicalGramProjection lambda alpha S -
        parameterizedCanonicalGramProjection lambda alpha S *
          ContinuousLinearMap.adjoint
            (parameterizedFiniteEulerGenerator alpha S) *
          parameterizedCanonicalGramProjection lambda alpha S := by
  unfold parameterizedCanonicalGramProjectionDerivative
  rw [ContinuousLinearMap.add_comp]
  rw [frameDerivative_gramInv_adjoint_eq_generator_mul_projection
      lambda alpha S halpha,
    frame_gramInverseDerivative_adjoint_eq_negative_diagonalBlocks
      lambda alpha S halpha,
    frame_gramInv_adjointDerivative_eq_projection_mul_adjointGenerator
      lambda alpha S halpha]
  abel

/-- Final same-object orthogonal projection derivative. -/
theorem parameterizedCanonicalGramProjectionDerivative_eq_orthogonalFlow
    (lambda : CCM24SoninScale) (alpha : ℝ)
    (S : List CCM24VisiblePrime) (halpha : |alpha| ≤ 1) :
    parameterizedCanonicalGramProjectionDerivative lambda alpha S halpha =
      orthogonalProjectionDerivative
        (parameterizedCanonicalGramProjection lambda alpha S)
        (parameterizedFiniteEulerGenerator alpha S) := by
  rw [parameterizedCanonicalGramProjectionDerivative_eq_expandedFlow
    lambda alpha S halpha]
  exact expandedGramDerivative_eq_orthogonalProjectionDerivative _ _
    (by
      rw [parameterizedCanonicalGramProjection_eq_soninProjection
        lambda alpha S halpha]
      exact (parameterizedSoninProjection_isStarProjection
        lambda alpha S halpha).isSelfAdjoint)

end CCM24FiniteSGramFlowCollapse
end CCM25Concrete
end Source
end ConnesWeilRH
