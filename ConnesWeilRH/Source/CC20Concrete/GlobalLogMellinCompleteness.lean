import ConnesWeilRH.Source.CC20Concrete.GlobalLogMellinRows
import ConnesWeilRH.Source.CC20Concrete.QuantizedRemainder
import Mathlib.Topology.ContinuousMap.StoneWeierstrass

/-!
# Completeness of natural Mellin rows on the finite logarithmic window

The Mellin rows at the natural-number nodes are already complete on every
nondegenerate compact logarithmic window.  In the log variable they are

`1, exp(t), exp(2 * t), ...`.

They form a self-adjoint algebra, and `exp(t)` separates points.  The complex
Stone-Weierstrass theorem therefore makes their span dense in the continuous
functions.  Density of continuous functions in `L2`, followed by the two
existing exact isometries, gives dense span on both the restricted-log and
Haar carriers.

This removes the explicit row-span containment premise for the ordinary
finite-window regular operator: compactness selects finitely many actual
natural Mellin equations.  It does not identify that ordinary operator with
the finite-S post-Q semilocal remainder.
-/

namespace ConnesWeilRH
namespace Source
namespace CC20Concrete

open MeasureTheory Set
open Complex
open scoped ComplexConjugate InnerProduct InnerProductSpace

noncomputable local instance cc20MellinCompletenessLogWindowCompactSpace
    (lambda : ℝ) : CompactSpace (CC20LogWindowPoint lambda) := by
  unfold CC20LogWindowPoint cc20LogWindow
  infer_instance

/-- The continuous Mellin row at the natural-number node `n`. -/
noncomputable def cc20NaturalMellinRowContinuous
    (lambda : ℝ) (n : ℕ) : ContinuousMap (CC20LogWindowPoint lambda) ℂ :=
  cc20LogMellinRowContinuous lambda (n : ℂ)

theorem cc20NaturalMellinRowContinuous_zero (lambda : ℝ) :
    cc20NaturalMellinRowContinuous lambda 0 = 1 := by
  ext t
  simp [cc20NaturalMellinRowContinuous, cc20LogMellinRowContinuous]

theorem cc20NaturalMellinRowContinuous_mul
    (lambda : ℝ) (m n : ℕ) :
    cc20NaturalMellinRowContinuous lambda m *
        cc20NaturalMellinRowContinuous lambda n =
      cc20NaturalMellinRowContinuous lambda (m + n) := by
  ext t
  simp [cc20NaturalMellinRowContinuous, cc20LogMellinRowContinuous,
    add_mul, Complex.exp_add]

theorem star_cc20NaturalMellinRowContinuous
    (lambda : ℝ) (n : ℕ) :
    star (cc20NaturalMellinRowContinuous lambda n) =
      cc20NaturalMellinRowContinuous lambda n := by
  ext t
  change star (star (Complex.exp ((n : ℂ) * (t.1 : ℂ)))) =
    star (Complex.exp ((n : ℂ) * (t.1 : ℂ)))
  simp only [star_star]
  change Complex.exp ((n : ℂ) * (t.1 : ℂ)) =
    conj (Complex.exp ((n : ℂ) * (t.1 : ℂ)))
  rw [← Complex.exp_conj]
  congr 1
  simp

/-- The first natural Mellin row is `exp(t)`, so it separates points of the
closed logarithmic interval. -/
theorem cc20NaturalMellinRowContinuous_one_ne
    (lambda : ℝ) (x y : CC20LogWindowPoint lambda) (hxy : x ≠ y) :
    cc20NaturalMellinRowContinuous lambda 1 x ≠
      cc20NaturalMellinRowContinuous lambda 1 y := by
  have hx : cc20NaturalMellinRowContinuous lambda 1 x =
      (Real.exp x.1 : ℂ) := by
    simp [cc20NaturalMellinRowContinuous, cc20LogMellinRowContinuous,
      ← Complex.ofReal_exp]
  have hy : cc20NaturalMellinRowContinuous lambda 1 y =
      (Real.exp y.1 : ℂ) := by
    simp [cc20NaturalMellinRowContinuous, cc20LogMellinRowContinuous,
      ← Complex.ofReal_exp]
  rw [hx, hy]
  exact_mod_cast Real.exp_injective.ne (Subtype.coe_ne_coe.mpr hxy)

/-- The star subalgebra generated by the natural Mellin rows. -/
noncomputable def cc20NaturalMellinRowStarSubalgebra
    (lambda : ℝ) :
    StarSubalgebra ℂ C(CC20LogWindowPoint lambda, ℂ) where
  toSubalgebra := Algebra.adjoin ℂ
    (Set.range (cc20NaturalMellinRowContinuous lambda))
  star_mem' := by
    change Algebra.adjoin ℂ
        (Set.range (cc20NaturalMellinRowContinuous lambda)) ≤
      star (Algebra.adjoin ℂ
        (Set.range (cc20NaturalMellinRowContinuous lambda)))
    refine Algebra.adjoin_le ?_
    rintro _ ⟨n, rfl⟩
    exact Algebra.subset_adjoin ⟨n,
      (star_cc20NaturalMellinRowContinuous lambda n).symm⟩

/-- Because products add natural nodes, the generated algebra is exactly the
linear span of the original rows. -/
theorem cc20NaturalMellinRowStarSubalgebra_coe
    (lambda : ℝ) :
    (cc20NaturalMellinRowStarSubalgebra lambda).toSubalgebra.toSubmodule =
      Submodule.span ℂ
        (Set.range (cc20NaturalMellinRowContinuous lambda)) := by
  apply Algebra.adjoin_eq_span_of_subset
  refine Set.Subset.trans ?_ Submodule.subset_span
  intro x hx
  refine Submonoid.closure_induction (fun _ => id) ⟨0, ?_⟩ ?_ hx
  · exact cc20NaturalMellinRowContinuous_zero lambda
  · rintro _ _ _ _ ⟨m, rfl⟩ ⟨n, rfl⟩
    exact ⟨m + n,
      (cc20NaturalMellinRowContinuous_mul lambda m n).symm⟩

theorem cc20NaturalMellinRowStarSubalgebra_separatesPoints
    (lambda : ℝ) :
    (cc20NaturalMellinRowStarSubalgebra lambda).SeparatesPoints := by
  intro x y hxy
  refine ⟨_, ⟨cc20NaturalMellinRowContinuous lambda 1,
    Algebra.subset_adjoin ⟨1, rfl⟩, rfl⟩, ?_⟩
  exact cc20NaturalMellinRowContinuous_one_ne lambda x y hxy

theorem cc20NaturalMellinRowStarSubalgebra_closure_eq_top
    (lambda : ℝ) :
    (cc20NaturalMellinRowStarSubalgebra lambda).topologicalClosure = ⊤ :=
  ContinuousMap.starSubalgebra_topologicalClosure_eq_top_of_separatesPoints _
    (cc20NaturalMellinRowStarSubalgebra_separatesPoints lambda)

theorem span_cc20NaturalMellinRowContinuous_closure_eq_top
    (lambda : ℝ) :
    (Submodule.span ℂ
      (Set.range (cc20NaturalMellinRowContinuous lambda))).topologicalClosure = ⊤ := by
  rw [← cc20NaturalMellinRowStarSubalgebra_coe]
  exact congrArg
    (fun A : StarSubalgebra ℂ C(CC20LogWindowPoint lambda, ℂ) =>
      A.toSubalgebra.toSubmodule)
    (cc20NaturalMellinRowStarSubalgebra_closure_eq_top lambda)

/-- The natural Mellin rows on the compact-subtype `L2` carrier. -/
noncomputable def cc20NaturalMellinRow
    (lambda : ℝ) (n : ℕ) :
    Lp ℂ 2 (cc20LogWindowBaseMeasure lambda) :=
  cc20LogMellinRow lambda (n : ℂ)

theorem span_cc20NaturalMellinRow_closure_eq_top
    (lambda : ℝ) :
    (Submodule.span ℂ
      (Set.range (cc20NaturalMellinRow lambda))).topologicalClosure = ⊤ := by
  have hp : (2 : ENNReal) ≠ ⊤ := by norm_num
  convert!
    (ContinuousMap.toLp_denseRange ℂ
      (cc20LogWindowBaseMeasure lambda) ℂ hp).topologicalClosure_map_submodule
      (span_cc20NaturalMellinRowContinuous_closure_eq_top lambda)
  rw [Submodule.map_span]
  unfold cc20NaturalMellinRow cc20LogMellinRow
    cc20NaturalMellinRowContinuous
  rw [Set.range_comp']
  simp only [ContinuousLinearMap.coe_coe]

theorem dense_span_cc20NaturalMellinRow (lambda : ℝ) :
    Dense (Submodule.span ℂ
      (Set.range (cc20NaturalMellinRow lambda)) : Set
        (Lp ℂ 2 (cc20LogWindowBaseMeasure lambda))) := by
  exact Submodule.dense_iff_topologicalClosure_eq_top.mpr
    (span_cc20NaturalMellinRow_closure_eq_top lambda)

/-- The natural Mellin rows on the restricted-log `L2` carrier. -/
noncomputable def cc20RestrictedLogNaturalMellinRow
    (lambda : ℝ) (n : ℕ) :
    Lp ℂ 2 (volume.restrict (cc20LogWindow lambda)) :=
  cc20RestrictedLogMellinRow lambda (n : ℂ)

theorem span_cc20RestrictedLogNaturalMellinRow_closure_eq_top
    (lambda : ℝ) :
    (Submodule.span ℂ
      (Set.range
        (cc20RestrictedLogNaturalMellinRow lambda))).topologicalClosure = ⊤ := by
  let e := (cc20LogWindowSubtypeRestrictedL2IsometryEquiv lambda).symm
  let f := e.toContinuousLinearEquiv.toContinuousLinearMap
  have hdenseRange : DenseRange f := e.surjective.denseRange
  have hmap := hdenseRange.topologicalClosure_map_submodule
    (span_cc20NaturalMellinRow_closure_eq_top lambda)
  rw [Submodule.map_span] at hmap
  change (Submodule.span ℂ
    ((fun a => f a) ''
      Set.range (cc20NaturalMellinRow lambda))).topologicalClosure = ⊤ at hmap
  have hfe : (fun a => f a) = (fun a => e a) := by
    funext a
    rfl
  rw [hfe] at hmap
  unfold cc20RestrictedLogNaturalMellinRow cc20RestrictedLogMellinRow
  rw [Set.range_comp']
  simpa [cc20NaturalMellinRow, e] using hmap

theorem dense_span_cc20RestrictedLogNaturalMellinRow (lambda : ℝ) :
    Dense (Submodule.span ℂ
      (Set.range (cc20RestrictedLogNaturalMellinRow lambda)) : Set
        (Lp ℂ 2 (volume.restrict (cc20LogWindow lambda)))) := by
  exact Submodule.dense_iff_topologicalClosure_eq_top.mpr
    (span_cc20RestrictedLogNaturalMellinRow_closure_eq_top lambda)

/-- The same complete natural Mellin family on the Haar carrier. -/
noncomputable def cc20WindowHaarNaturalMellinRow
    (lambda : ℝ) (hlambda : 1 < lambda) (n : ℕ) :
    Lp ℂ 2 (cc20WindowHaarMeasure lambda hlambda) :=
  cc20WindowHaarMellinRow lambda hlambda (n : ℂ)

theorem span_cc20WindowHaarNaturalMellinRow_closure_eq_top
    (lambda : ℝ) (hlambda : 1 < lambda) :
    (Submodule.span ℂ
      (Set.range
        (cc20WindowHaarNaturalMellinRow lambda hlambda))).topologicalClosure = ⊤ := by
  let e := (cc20WindowHaarRestrictedLogL2IsometryEquiv lambda hlambda).symm
  let f := e.toContinuousLinearEquiv.toContinuousLinearMap
  have hdenseRange : DenseRange f := e.surjective.denseRange
  have hmap := hdenseRange.topologicalClosure_map_submodule
    (span_cc20RestrictedLogNaturalMellinRow_closure_eq_top lambda)
  rw [Submodule.map_span] at hmap
  change (Submodule.span ℂ
    ((fun a => f a) ''
      Set.range
        (cc20RestrictedLogNaturalMellinRow lambda))).topologicalClosure = ⊤ at hmap
  have hfe : (fun a => f a) = (fun a => e a) := by
    funext a
    rfl
  rw [hfe] at hmap
  unfold cc20WindowHaarNaturalMellinRow cc20WindowHaarMellinRow
  rw [Set.range_comp']
  simpa [cc20RestrictedLogNaturalMellinRow, e] using hmap

theorem dense_span_cc20WindowHaarNaturalMellinRow
    (lambda : ℝ) (hlambda : 1 < lambda) :
    Dense (Submodule.span ℂ
      (Set.range (cc20WindowHaarNaturalMellinRow lambda hlambda)) : Set
        (Lp ℂ 2 (cc20WindowHaarMeasure lambda hlambda))) := by
  exact Submodule.dense_iff_topologicalClosure_eq_top.mpr
    (span_cc20WindowHaarNaturalMellinRow_closure_eq_top lambda hlambda)

/-- Compactness selects finitely many actual natural Mellin rows whose
orthogonal complement makes the shifted ordinary Haar remainder
nonpositive. -/
theorem exists_finite_cc20WindowHaarNaturalMellinControlRows
    (lambda : ℝ) (hlambda : 1 < lambda) :
    ∃ rowIndices : Finset ℕ,
      FiniteDimensional ℂ
          (Submodule.span ℂ
            ((cc20WindowHaarNaturalMellinRow lambda hlambda) ''
              (rowIndices : Set ℕ))) ∧
        ∀ x : Lp ℂ 2 (cc20WindowHaarMeasure lambda hlambda),
          (∀ n ∈ rowIndices,
            inner ℂ x
              (cc20WindowHaarNaturalMellinRow lambda hlambda n) = 0) →
            (inner ℂ x
              (cc20WindowHaarComplexL2Operator lambda hlambda x -
                (2 : ℂ) • x)).re ≤ 0 := by
  exact CompactBadSpace.exists_finite_controlRowIndices_of_dense_span
    (cc20WindowHaarComplexL2Operator lambda hlambda)
    (isCompactOperator_cc20WindowHaarComplexL2Operator lambda hlambda)
    (cc20WindowHaarNaturalMellinRow lambda hlambda)
    (dense_span_cc20WindowHaarNaturalMellinRow lambda hlambda)
    (by norm_num)

/-- Containment-free source-test form: finitely many natural Mellin zeros
control the shifted ordinary finite-window regular operator. -/
theorem exists_finite_cc20WindowHaarNaturalMellinZeros_remainder_nonpositive
    (lambda : ℝ) (hlambda : 1 < lambda) :
    ∃ rowIndices : Finset ℕ,
      FiniteDimensional ℂ
          (Submodule.span ℂ
            ((cc20WindowHaarNaturalMellinRow lambda hlambda) ''
              (rowIndices : Set ℕ))) ∧
        ∀ (g : normalizedCC20ConcreteTestAlgebra.Test),
          Function.support
              (fun x : ℝ =>
                normalizedCC20ConcreteTestAlgebra.legacy.encode g x) ⊆
            Set.Ioo (1 / lambda) lambda →
          (∀ n ∈ rowIndices,
            normalizedCC20TestSpace.mellinAt g (n : ℂ) = 0) →
          (inner ℂ
            (cc20WindowHaarMellinTestInput lambda hlambda g)
            (cc20WindowHaarComplexL2Operator lambda hlambda
                (cc20WindowHaarMellinTestInput lambda hlambda g) -
              (2 : ℂ) •
                cc20WindowHaarMellinTestInput lambda hlambda g)).re ≤ 0 := by
  obtain ⟨rowIndices, hfinite, hsign⟩ :=
    exists_finite_cc20WindowHaarNaturalMellinControlRows lambda hlambda
  refine ⟨rowIndices, hfinite, ?_⟩
  intro g hsupport hzeros
  apply hsign (cc20WindowHaarMellinTestInput lambda hlambda g)
  intro n hn
  exact (cc20WindowHaarMellinTestInput_inner_row_eq_zero_iff
    lambda hlambda (n : ℂ) g hsupport).mpr (hzeros n hn)

/-- Compactness and natural Mellin completeness select finitely many actual
rows which control the named restricted `K_I - 2 Id` owner. -/
theorem
    exists_finite_cc20RestrictedLogNaturalMellinControlRows_quantizedRemainder_nonpositive
    (lambda : ℝ) (hlambda : 1 < lambda) :
    ∃ rowIndices : Finset ℕ,
      FiniteDimensional ℂ
          (Submodule.span ℂ
            ((cc20RestrictedLogNaturalMellinRow lambda) ''
              (rowIndices : Set ℕ))) ∧
        ∀ x : Lp ℂ 2 (volume.restrict (cc20LogWindow lambda)),
          (∀ n ∈ rowIndices,
            inner ℂ x (cc20RestrictedLogNaturalMellinRow lambda n) = 0) →
          (inner ℂ x
            (cc20GlobalLogWindowRestrictedQuantizedRemainder
              lambda hlambda x)).re ≤ 0 := by
  obtain ⟨rowIndices, hfinite, hsign⟩ :=
    CompactBadSpace.exists_finite_controlRowIndices_of_dense_span
      (threshold := 2)
      (cc20GlobalLogWindowRestrictedL2Endomorphism lambda hlambda)
      (isCompactOperator_cc20GlobalLogWindowRestrictedL2Endomorphism
        lambda hlambda)
      (cc20RestrictedLogNaturalMellinRow lambda)
      (dense_span_cc20RestrictedLogNaturalMellinRow lambda)
      (by norm_num)
  refine ⟨rowIndices, hfinite, ?_⟩
  intro x hzeros
  rw [cc20GlobalLogWindowRestrictedQuantizedRemainder_apply]
  exact hsign x hzeros

/-- The same named-owner sign statement for actual source tests satisfying a
finite family of natural Mellin zero equations. -/
theorem
    exists_finite_cc20RestrictedLogNaturalMellinZeros_quantizedRemainder_nonpositive
    (lambda : ℝ) (hlambda : 1 < lambda) :
    ∃ rowIndices : Finset ℕ,
      FiniteDimensional ℂ
          (Submodule.span ℂ
            ((cc20RestrictedLogNaturalMellinRow lambda) ''
              (rowIndices : Set ℕ))) ∧
        ∀ (g : normalizedCC20ConcreteTestAlgebra.Test),
          Function.support
              (fun x : ℝ =>
                normalizedCC20ConcreteTestAlgebra.legacy.encode g x) ⊆
            Set.Ioo (1 / lambda) lambda →
          (∀ n ∈ rowIndices,
            normalizedCC20TestSpace.mellinAt g (n : ℂ) = 0) →
          (inner ℂ (cc20RestrictedLogMellinTestInput lambda g)
            (cc20GlobalLogWindowRestrictedQuantizedRemainder lambda hlambda
              (cc20RestrictedLogMellinTestInput lambda g))).re ≤ 0 := by
  obtain ⟨rowIndices, hfinite, hsign⟩ :=
    exists_finite_cc20RestrictedLogNaturalMellinControlRows_quantizedRemainder_nonpositive
      lambda hlambda
  refine ⟨rowIndices, hfinite, ?_⟩
  intro g hsupport hzeros
  apply hsign (cc20RestrictedLogMellinTestInput lambda g)
  intro n hn
  change inner ℂ (cc20RestrictedLogMellinTestInput lambda g)
      (cc20RestrictedLogMellinRow lambda (n : ℂ)) = 0
  exact (cc20RestrictedLogMellinTestInput_inner_row_eq_zero_iff
    lambda hlambda (n : ℂ) g hsupport).mpr (hzeros n hn)

/-- Zero extension puts the same finite-Mellin sign theorem on the global
logarithmic Hilbert space without changing its quadratic form. -/
theorem
    exists_finite_cc20GlobalLogNaturalMellinZeros_quantizedRemainder_nonpositive
    (lambda : ℝ) (hlambda : 1 < lambda) :
    ∃ rowIndices : Finset ℕ,
      FiniteDimensional ℂ
          (Submodule.span ℂ
            ((cc20RestrictedLogNaturalMellinRow lambda) ''
              (rowIndices : Set ℕ))) ∧
        ∀ (g : normalizedCC20ConcreteTestAlgebra.Test),
          Function.support
              (fun x : ℝ =>
                normalizedCC20ConcreteTestAlgebra.legacy.encode g x) ⊆
            Set.Ioo (1 / lambda) lambda →
          (∀ n ∈ rowIndices,
            normalizedCC20TestSpace.mellinAt g (n : ℂ) = 0) →
          (inner ℂ
            (cc20LogWindowRestrictIndicatorCLM lambda
              (cc20RestrictedLogMellinTestInput lambda g))
            (cc20GlobalLogWindowQuantizedRemainder lambda hlambda
              (cc20LogWindowRestrictIndicatorCLM lambda
                (cc20RestrictedLogMellinTestInput lambda g)))).re ≤ 0 := by
  obtain ⟨rowIndices, hfinite, hsign⟩ :=
    exists_finite_cc20RestrictedLogNaturalMellinZeros_quantizedRemainder_nonpositive
      lambda hlambda
  refine ⟨rowIndices, hfinite, ?_⟩
  intro g hsupport hzeros
  rw [cc20GlobalLogWindowQuantizedRemainder_inner_zeroExtension]
  exact hsign g hsupport hzeros

